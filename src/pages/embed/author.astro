---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="OT / author">
  <div class="embed">
    <pre class="art" aria-label="ascii art otras tecnologias">
OTRAS TECNOLOGIAS
================
    </pre>

    <div class="text">
      <p><strong>POLBAC</strong></p>
      <p class="muted">
        OT is also a POLBAC EP and an ongoing archive of resources about technology, commons, DIY,
        open-source, democracy, peace, art, progress, community, cooperation, and mutual aid.
      </p>
      <p class="muted">[ more soon ]</p>
    </div>
  </div>

  <style>
    .embed {
      padding: 10px;
    }
    .art {
      margin: 0 0 10px;
      white-space: pre;
      color: var(--fg);
      line-height: 1.1;
      font-size: 12px;
    }
    .text p {
      margin: 0 0 10px;
    }
  </style>
</BaseLayout>

