---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="OT / author">
  <div class="embed">
    <pre class="art" aria-label="ascii art otras tecnologias">
OTRAS TECNOLOGIAS
================
    </pre>

    <div class="text">
      <p><strong>AUTHOR</strong></p>
      <p class="muted">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer nec odio praesent libero.
        Sed cursus ante dapibus diam.
      </p>
      <p class="muted">
        Sed nisi. Nulla quis sem at nibh elementum imperdiet. Duis sagittis ipsum. Praesent mauris.
      </p>
    </div>
  </div>

  <style>
    .embed {
      padding: 10px;
    }
    .art {
      margin: 0 0 10px;
      white-space: pre;
      color: var(--fg);
      line-height: 1.1;
      font-size: 12px;
    }
    .text p {
      margin: 0 0 10px;
    }
  </style>
</BaseLayout>

