---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const all = await getCollection("resources");
const items = all
  .slice()
  .sort((a, b) => a.data.title.localeCompare(b.data.title, "en", { sensitivity: "base" }));
const tags = Array.from(new Set(items.flatMap((r) => r.data.tags))).sort((a, b) =>
  a.localeCompare(b, "en", { sensitivity: "base" }),
);
---

<BaseLayout title="OT / archive">
  <div class="screen">
    <header class="bar topbar">
      <div class="left">
        <span class="tag">OTRAS TECNOLOGIAS (OT)</span>
        <span class="muted">/</span>
        <span class="tag">ARCHIVE</span>
      </div>
      <div class="right">
        <a class="link" href="/about/" data-action="manifest">[ manifesto ]</a>
        <a class="link" href="/embed/author/" data-action="author">[ author ]</a>
      </div>
    </header>

    <section class="pane pane-top" aria-label="visor">
      <div class="pane-inner pane-inner-top">
        <iframe
          id="viewer"
          title="visor"
          class="viewer"
          src="/embed/about/"
          loading="eager"
        />
      </div>
    </section>

    <div class="divider" role="separator" aria-label="resize" tabindex="0"></div>

    <section class="pane pane-bottom" aria-label="archive">
      <div class="pane-inner pane-inner-bottom">
        <div class="pane-title">
          <span class="muted">archive</span>
          <span class="muted">·</span>
          <span class="tag">{items.length} resources</span>
        </div>

        <div class="toolbar">
          <label class="search">
            <span class="muted">search</span>
            <input id="q" class="input" type="text" placeholder="title / author / tag…" />
          </label>
          <button id="filters" class="filters-button" type="button">[ filters ]</button>
          <div class="active muted">
            <span id="filterState">—</span>
            <button id="clear" class="clear" type="button" hidden>[ clear ]</button>
          </div>
        </div>

        <div
          id="filtersModal"
          class="filter-modal"
          role="dialog"
          aria-modal="true"
          aria-labelledby="filtersTitle"
          aria-hidden="true"
          hidden
        >
          <div class="filter-dialog">
            <header class="filter-titlebar">
              <span id="filtersTitle">TAGS</span>
              <button id="filtersClose" class="modal-close" type="button">[ X ]</button>
            </header>
            <div class="filter-body">
              <p class="muted">select one tag</p>
              <div class="filter-grid">
                {tags.map((tag) => (
                  <button class="filter-tag" type="button" data-tag={tag}>
                    {tag}
                  </button>
                ))}
              </div>
            </div>
            <footer class="filter-actions">
              <button id="filtersClear" class="clear" type="button" hidden>[ clear ]</button>
              <button id="filtersCancel" class="clear" type="button">[ cancel ]</button>
            </footer>
          </div>
        </div>

        <div class="tableWrap" role="region" aria-label="resources table">
          <table class="table">
            <thead>
              <tr>
                <th class="col-id">#</th>
                <th>Name</th>
                <th class="col-desc">Tags</th>
                <th class="col-year">Year</th>
                <th class="col-author">Author</th>
              </tr>
            </thead>
            <tbody>
              {items.map((r, i) => (
                <tr
                  class="row"
                  data-slug={r.slug}
                  data-title={r.data.title}
                  data-year={String(r.data.createdAt.getUTCFullYear())}
                  data-tags={JSON.stringify(r.data.tags)}
                  data-authors={r.data.authors.join(" ")}
                >
                  <td class="col-id">{String(i + 1).padStart(2, "0")}</td>
                  <td class="name">
                    <a class="rowlink" href={`/resources/${r.slug}/`} target="_blank" rel="noreferrer">
                      {r.data.title}
                    </a>
                    <span class="muted">{" "}[ view ]</span>
                  </td>
                  <td class="col-desc">
                    <div class="chips">
                      {r.data.tags.map((t) => (
                        <button class="chip" type="button" data-tag={t} title={`filter: ${t}`}>
                          {t}
                        </button>
                      ))}
                    </div>
                  </td>
                  <td class="col-year">{r.data.createdAt.getUTCFullYear()}</td>
                  <td class="col-author muted">{r.data.authors.join(", ")}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <footer class="bar bottombar">
          <div class="left muted">OT</div>
        </footer>
      </div>
    </section>
  </div>

  <script is:inline>
    const viewer = /** @type {HTMLIFrameElement | null} */ (document.getElementById("viewer"));
    const screen = /** @type {HTMLElement | null} */ (document.querySelector(".screen"));
    const divider = /** @type {HTMLElement | null} */ (document.querySelector(".divider"));
    const manifestLink = /** @type {HTMLAnchorElement | null} */ (
      document.querySelector('a[data-action="manifest"]')
    );
    const authorLink = /** @type {HTMLAnchorElement | null} */ (
      document.querySelector('a[data-action="author"]')
    );
    const q = /** @type {HTMLInputElement | null} */ (document.getElementById("q"));
    const filterState = /** @type {HTMLElement | null} */ (document.getElementById("filterState"));
    const clearBtn = /** @type {HTMLButtonElement | null} */ (document.getElementById("clear"));
    const filtersBtn = /** @type {HTMLButtonElement | null} */ (document.getElementById("filters"));
    const filtersModal = /** @type {HTMLElement | null} */ (document.getElementById("filtersModal"));
    const filtersClose = /** @type {HTMLButtonElement | null} */ (
      document.getElementById("filtersClose")
    );
    const filtersCancel = /** @type {HTMLButtonElement | null} */ (
      document.getElementById("filtersCancel")
    );
    const filtersClear = /** @type {HTMLButtonElement | null} */ (
      document.getElementById("filtersClear")
    );
    const rows = /** @type {NodeListOf<HTMLTableRowElement>} */ (
      document.querySelectorAll("tr.row[data-slug]")
    );
    const chips = /** @type {NodeListOf<HTMLButtonElement>} */ (
      document.querySelectorAll("button.chip[data-tag]")
    );
    const filterTags = /** @type {NodeListOf<HTMLButtonElement>} */ (
      document.querySelectorAll("button.filter-tag[data-tag]")
    );

    function selectRow(row) {
      rows.forEach((r) => r.classList.remove("selected"));
      row.classList.add("selected");
    }

    function clearSelection() {
      rows.forEach((r) => r.classList.remove("selected"));
    }

    rows.forEach((row) => {
      row.addEventListener("click", (e) => {
        // Si clickean el link directo, no interferimos con el visor.
        if (/** @type {MouseEvent} */ (e).target?.closest?.("a")) return;
        if (/** @type {MouseEvent} */ (e).target?.closest?.("button.chip")) return;
        const slug = row.dataset.slug;
        if (!viewer || !slug) return;
        viewer.src = `/embed/resources/${slug}/`;
        selectRow(row);
      });
    });

    if (manifestLink) {
      manifestLink.addEventListener("click", (e) => {
        e.preventDefault();
        if (!viewer) return;
        viewer.src = "/embed/about/";
        clearSelection();
      });
    }

    if (authorLink) {
      authorLink.addEventListener("click", (e) => {
        e.preventDefault();
        if (!viewer) return;
        viewer.src = "/embed/author/";
        clearSelection();
      });
    }

    // --- filter/search
    let tagFilter = "";

    function getRowTags(row) {
      try {
        const parsed = JSON.parse(row.dataset.tags || "[]");
        return Array.isArray(parsed) ? parsed.map((tag) => String(tag).toLowerCase()) : [];
      } catch {
        return [];
      }
    }

    function syncFilterControls() {
      const hasActive = Boolean(tagFilter || q?.value?.trim());
      clearBtn && (clearBtn.hidden = !hasActive);
      filtersClear && (filtersClear.hidden = !hasActive);
      chips.forEach((b) => b.classList.toggle("active", b.dataset.tag === tagFilter));
      filterTags.forEach((b) => b.classList.toggle("active", b.dataset.tag === tagFilter));
    }

    function setStateLabel() {
      if (!filterState) return;
      const parts = [];
      if (tagFilter) parts.push(`tag:${tagFilter}`);
      if (q?.value?.trim()) parts.push(`q:${q.value.trim()}`);
      filterState.textContent = parts.length ? parts.join(" ") : "—";
      syncFilterControls();
    }

    function applyFilter() {
      const query = (q?.value ?? "").trim().toLowerCase();
      rows.forEach((row) => {
        const title = (row.dataset.title ?? "").toLowerCase();
        const authors = (row.dataset.authors ?? "").toLowerCase();
        const tags = getRowTags(row);
        const searchableTags = tags.join(" ");
        const okTag = tagFilter ? tags.includes(tagFilter.toLowerCase()) : true;
        const okQuery = query
          ? title.includes(query) || authors.includes(query) || searchableTags.includes(query)
          : true;
        row.style.display = okTag && okQuery ? "" : "none";
      });
      setStateLabel();
    }

    function closeFiltersModal() {
      if (!filtersModal) return;
      filtersModal.hidden = true;
      filtersModal.setAttribute("aria-hidden", "true");
      filtersBtn?.focus();
    }

    function openFiltersModal() {
      if (!filtersModal) return;
      filtersModal.hidden = false;
      filtersModal.setAttribute("aria-hidden", "false");
      const active = filtersModal.querySelector("button.filter-tag.active");
      const firstTag = filtersModal.querySelector("button.filter-tag");
      (active || firstTag || filtersClose)?.focus?.();
    }

    function clearFilters() {
      tagFilter = "";
      if (q) q.value = "";
      applyFilter();
    }

    chips.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        const t = btn.dataset.tag || "";
        tagFilter = tagFilter === t ? "" : t;
        applyFilter();
      });
    });

    filterTags.forEach((btn) => {
      btn.addEventListener("click", () => {
        const t = btn.dataset.tag || "";
        tagFilter = tagFilter === t ? "" : t;
        applyFilter();
        closeFiltersModal();
      });
    });

    filtersBtn?.addEventListener("click", () => openFiltersModal());
    filtersClose?.addEventListener("click", () => closeFiltersModal());
    filtersCancel?.addEventListener("click", () => closeFiltersModal());
    filtersClear?.addEventListener("click", () => {
      clearFilters();
      closeFiltersModal();
    });
    filtersModal?.addEventListener("click", (e) => {
      if (e.target === filtersModal) closeFiltersModal();
    });
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && filtersModal && !filtersModal.hidden) closeFiltersModal();
    });

    q?.addEventListener("input", () => applyFilter());
    clearBtn?.addEventListener("click", () => clearFilters());
    applyFilter();

    // --- draggable split
    function clamp(n, a, b) {
      return Math.max(a, Math.min(b, n));
    }
    function setSplitPx(topPx) {
      if (!screen) return;
      const minTop = 140;
      const minBottom = 180;
      const total = screen.clientHeight;
      const topbar = 30;
      const divH = 6;
      const maxTop = total - topbar - divH - minBottom;
      const t = clamp(topPx, minTop, maxTop);
      screen.style.gridTemplateRows = `${topbar}px ${t}px ${divH}px 1fr`;
      localStorage.setItem("ot_split_top_px", String(t));
    }
    (function initSplit() {
      if (!screen) return;
      const saved = Number(localStorage.getItem("ot_split_top_px"));
      if (Number.isFinite(saved) && saved > 0) {
        setSplitPx(saved);
      } else {
        // default 50/50
        const topbar = 30;
        const divH = 6;
        const t = Math.floor((screen.clientHeight - topbar - divH) / 2);
        setSplitPx(t);
      }
    })();

    if (divider && screen) {
      let dragging = false;

      const onMove = (ev) => {
        if (!dragging) return;
        const rect = screen.getBoundingClientRect();
        const y = ev.clientY - rect.top;
        // y = topbar + topPaneHeight
        const topPx = Math.floor(y - 30);
        setSplitPx(topPx);
      };

      const stop = () => {
        dragging = false;
        window.removeEventListener("pointermove", onMove);
        window.removeEventListener("pointerup", stop);
        divider.releasePointerCapture?.(1);
      };

      divider.addEventListener("pointerdown", (e) => {
        dragging = true;
        divider.setPointerCapture?.(e.pointerId);
        window.addEventListener("pointermove", onMove);
        window.addEventListener("pointerup", stop);
      });
    }
  </script>

  <style>
    .screen {
      height: 100vh;
      display: grid;
      /* topbar + topPane + divider + bottomPane */
      grid-template-rows: 30px 1fr 6px 1fr;
      gap: 0;
    }

    .bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 10px;
      border-bottom: 1px solid var(--border);
      background: rgba(0, 0, 0, 0.08);
      backdrop-filter: blur(2px);
    }

    .topbar {
      border-bottom: 1px solid rgba(255, 255, 255, 0.35);
    }

    .bottombar {
      border-top: 1px solid rgba(255, 255, 255, 0.35);
      border-bottom: none;
      gap: 12px;
      justify-content: flex-start;
    }

    .bar .left,
    .bar .right {
      display: flex;
      gap: 10px;
      align-items: center;
      white-space: nowrap;
    }

    .link {
      color: var(--accent);
    }

    .tag {
      color: var(--fg);
    }

    .pane {
      border-top: 1px solid rgba(255, 255, 255, 0.15);
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
      background: var(--panel);
      overflow: hidden;
    }

    .divider {
      background: rgba(255, 255, 255, 0.25);
      cursor: row-resize;
    }
    .divider:hover {
      background: rgba(255, 234, 0, 0.5);
    }

    .pane-inner {
      height: 100%;
      display: grid;
      grid-template-rows: 24px 1fr;
    }

    .pane-inner-top {
      display: block;
    }

    .pane-inner-bottom {
      grid-template-rows: 24px 34px 1fr auto;
    }

    .toolbar {
      display: flex;
      gap: 12px;
      align-items: center;
      padding: 4px 10px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(0, 0, 0, 0.08);
      font-size: 12px;
    }

    .search {
      display: flex;
      gap: 8px;
      align-items: center;
      flex: 1;
      min-width: 220px;
    }

    .input {
      width: min(520px, 100%);
      background: rgba(0, 0, 0, 0.15);
      color: var(--fg);
      border: 1px solid rgba(255, 255, 255, 0.35);
      padding: 4px 8px;
      outline: none;
    }

    .input:focus {
      border-color: var(--accent);
    }

    .active {
      display: flex;
      gap: 8px;
      align-items: center;
      white-space: nowrap;
    }

    .clear,
    .filters-button,
    .modal-close,
    .filter-tag {
      font-family: var(--mono);
      background: transparent;
      color: var(--fg);
      border: 1px solid rgba(255, 255, 255, 0.35);
      padding: 3px 8px;
      cursor: pointer;
    }

    .clear:hover,
    .filters-button:hover,
    .modal-close:hover,
    .filter-tag:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .filter-modal {
      position: fixed;
      inset: 0;
      z-index: 20;
      display: grid;
      place-items: center;
      padding: 18px;
      background: rgba(0, 0, 0, 0.45);
    }

    .filter-modal[hidden] {
      display: none;
    }

    .filter-dialog {
      width: min(720px, calc(100vw - 36px));
      max-height: min(620px, calc(100vh - 36px));
      display: grid;
      grid-template-rows: auto 1fr auto;
      border: 2px solid var(--border);
      background: var(--panel);
      box-shadow: 12px 12px 0 rgba(0, 0, 0, 0.45);
    }

    .filter-titlebar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 10px;
      background: #b50000;
      color: #0b0b0b;
      border-bottom: 1px solid rgba(0, 0, 0, 0.55);
    }

    .modal-close {
      color: #0b0b0b;
      border-color: rgba(0, 0, 0, 0.45);
    }

    .modal-close:hover {
      color: #0b0b0b;
      border-color: #0b0b0b;
    }

    .filter-body {
      min-height: 0;
      overflow: auto;
      padding: 10px;
    }

    .filter-body p {
      margin: 0 0 10px;
    }

    .filter-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 6px;
    }

    .filter-tag {
      text-align: left;
      color: var(--muted);
      background: rgba(0, 0, 0, 0.15);
    }

    .filter-tag.active {
      border-color: var(--accent);
      color: var(--bg);
      background: var(--accent);
    }

    .filter-actions {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      padding: 8px 10px;
      border-top: 1px solid rgba(255, 255, 255, 0.25);
      background: rgba(0, 0, 0, 0.12);
    }

    .pane-title {
      display: flex;
      gap: 10px;
      align-items: center;
      padding: 0 10px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.25);
      background: rgba(0, 0, 0, 0.12);
      font-size: 12px;
    }

    .pane-top .viewer {
      width: 100%;
      height: 100%;
      border: 0;
      background: var(--panel);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .pane-bottom .tableWrap {
      overflow: auto;
    }

    .table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }

    thead th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: #b50000;
      color: #0b0b0b;
      text-align: left;
      padding: 6px 10px;
      border-bottom: 1px solid rgba(0, 0, 0, 0.35);
      white-space: nowrap;
    }

    tbody td {
      padding: 6px 10px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      vertical-align: top;
    }

    tbody tr.row {
      cursor: pointer;
    }

    tbody tr.row:hover {
      background: rgba(255, 255, 255, 0.08);
    }

    tbody tr.row.selected {
      background: rgba(255, 229, 122, 0.22);
      outline: 1px solid rgba(255, 229, 122, 0.6);
      outline-offset: -1px;
    }

    .col-id {
      width: 52px;
      white-space: nowrap;
      color: var(--muted);
    }
    .col-year {
      width: 84px;
      white-space: nowrap;
    }
    .col-author {
      width: 240px;
    }
    .col-desc {
      max-width: 560px;
    }

    .chips {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .chip {
      font-family: var(--mono);
      font-size: 12px;
      padding: 2px 6px;
      border: 1px solid rgba(255, 255, 255, 0.35);
      background: rgba(0, 0, 0, 0.12);
      color: var(--muted);
      cursor: pointer;
    }

    .chip:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .chip.active {
      border-color: var(--accent);
      color: var(--bg);
      background: var(--accent);
    }

    .name {
      color: var(--fg);
    }

    .rowlink {
      color: var(--fg);
      text-decoration: none;
    }

    .rowlink:hover {
      text-decoration: underline;
      color: var(--accent);
    }

  </style>
</BaseLayout>

